<!--
  JaCoCo Pragmatic Coverage Configuration

  Use this configuration when you want 100% coverage with sensible exclusions.

  WHEN TO USE:
  - Core libraries with main methods or CLI entry points
  - Projects with pure DTOs/POJOs (no logic)
  - Projects with private utility class constructors

  MAINTAINS 100% coverage on all TESTABLE business logic.

  Copy this into your pom.xml <build><plugins> section.
-->

<plugin>
    <groupId>org.jacoco</groupId>
    <artifactId>jacoco-maven-plugin</artifactId>
    <version>0.8.11</version>
    <dependencies>
        <dependency>
            <groupId>org.flossware</groupId>
            <artifactId>jbuild-tools</artifactId>
            <version>1.4</version>
        </dependency>
    </dependencies>
    <configuration>
        <!-- Load exclusions from jbuild-tools -->
        <excludes>
            <!-- Application entry points -->
            <exclude>**/*Application.class</exclude>
            <exclude>**/Main.class</exclude>
            <exclude>**/*Main.class</exclude>
            <exclude>**/*CLI.class</exclude>

            <!-- Utility class constructors -->
            <exclude>**/*Util.class</exclude>
            <exclude>**/*Utils.class</exclude>
            <exclude>**/*Helper.class</exclude>
            <exclude>**/*Constants.class</exclude>

            <!-- Pure data classes (no logic) -->
            <exclude>**/dto/**/*DTO.class</exclude>
            <exclude>**/model/**/*Record.class</exclude>

            <!-- Generated code -->
            <exclude>**/generated/**</exclude>
            <exclude>**/*Builder.class</exclude>
        </excludes>
    </configuration>
    <executions>
        <execution>
            <id>prepare-agent</id>
            <goals>
                <goal>prepare-agent</goal>
            </goals>
        </execution>
        <execution>
            <id>report</id>
            <phase>test</phase>
            <goals>
                <goal>report</goal>
            </goals>
        </execution>
        <execution>
            <id>check</id>
            <phase>verify</phase>
            <goals>
                <goal>check</goal>
            </goals>
            <configuration>
                <rules>
                    <rule>
                        <element>BUNDLE</element>
                        <limits>
                            <!-- 100% instruction coverage (excluding patterns above) -->
                            <limit>
                                <counter>INSTRUCTION</counter>
                                <value>COVEREDRATIO</value>
                                <minimum>1.00</minimum>
                            </limit>
                            <!-- 100% branch coverage -->
                            <limit>
                                <counter>BRANCH</counter>
                                <value>COVEREDRATIO</value>
                                <minimum>1.00</minimum>
                            </limit>
                            <!-- 100% line coverage -->
                            <limit>
                                <counter>LINE</counter>
                                <value>COVEREDRATIO</value>
                                <minimum>1.00</minimum>
                            </limit>
                            <!-- No missed classes -->
                            <limit>
                                <counter>CLASS</counter>
                                <value>MISSEDCOUNT</value>
                                <maximum>0</maximum>
                            </limit>
                        </limits>
                    </rule>
                </rules>
            </configuration>
        </execution>
    </executions>
</plugin>
