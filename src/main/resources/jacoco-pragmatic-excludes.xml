<!--
  FlossWare Pragmatic Coverage Exclusions

  This file defines sensible exclusions for JaCoCo coverage while maintaining
  the 100% standard for business logic.

  USE THIS FOR: Projects where 100% coverage with common-sense exclusions is appropriate

  Excludes:
  - Application entry points (main methods, *Application classes)
  - Private utility class constructors
  - Pure data classes with no logic (DTOs, Records, POJOs)
  - Generated code
  - Framework integration classes with minimal logic

  DOES NOT EXCLUDE: Business logic, services, validators, or any testable code
-->
<excludes>
    <!-- ========================================
         APPLICATION ENTRY POINTS
         These delegate to frameworks and have no testable logic
         ======================================== -->
    <exclude>**/*Application.class</exclude>
    <exclude>**/Main.class</exclude>
    <exclude>**/*Main.class</exclude>
    <exclude>**/*CLI.class</exclude>

    <!-- ========================================
         UTILITY CLASS CONSTRUCTORS
         Private constructors that only throw UnsupportedOperationException
         ======================================== -->
    <exclude>**/*Util.class</exclude>
    <exclude>**/*Utils.class</exclude>
    <exclude>**/*Helper.class</exclude>
    <exclude>**/*Helpers.class</exclude>
    <exclude>**/*Constants.class</exclude>

    <!-- ========================================
         PURE DATA CLASSES (No Logic)
         Only getters/setters, no validation or business logic
         ======================================== -->
    <exclude>**/dto/**/*DTO.class</exclude>
    <exclude>**/dto/**/*Request.class</exclude>
    <exclude>**/dto/**/*Response.class</exclude>
    <exclude>**/model/**/*Record.class</exclude>
    <exclude>**/entity/**/*Entity.class</exclude>

    <!-- ========================================
         GENERATED CODE
         Code generated by tools, not written by developers
         ======================================== -->
    <exclude>**/generated/**</exclude>
    <exclude>**/*Builder.class</exclude>
    <exclude>**/*_*</exclude>  <!-- Lombok/MapStruct generated classes -->

    <!-- ========================================
         CONFIGURATION CLASSES
         Spring/framework configuration with no logic
         ======================================== -->
    <exclude>**/config/**/*Config.class</exclude>
    <exclude>**/configuration/**/*Configuration.class</exclude>
</excludes>
